{
   "action": {
      "default_popup": "popup.html",
      "default_title": "__MSG_action_title__"
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "open-all-urls": {
         "description": "__MSG_cmd_open_all__",
         "suggested_key": {
            "default": "Ctrl+Shift+U",
            "mac": "Command+Shift+U"
         }
      },
      "search-tabs-bookmarks": {
         "description": "__MSG_cmd_search__",
         "suggested_key": {
            "default": "Alt+K",
            "mac": "Command+K"
         }
      }
   },
   "default_locale": "en",
   "description": "__MSG_ext_description__",
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "__MSG_ext_name__",
   "options_page": "options.html",
   "permissions": [ "storage", "tabs", "notifications", "bookmarks", "history", "topSites", "scripting", "activeTab" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.5.5",
   "web_accessible_resources": [
      {
         "matches": [ "<all_urls>" ],
         "resources": [ "search-overlay.css", "_locales/*/messages.json" ]
      }
   ]
}
