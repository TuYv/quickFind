{
   "action": {
      "default_popup": "popup.html",
      "default_title": "QuickFind - Search Tabs & Bookmarks"
   },
   "background": {
      "service_worker": "background.js"
   },
   "commands": {
      "open-all-urls": {
         "description": "Open all configured URLs",
         "suggested_key": {
            "default": "Ctrl+Shift+U",
            "mac": "Command+Shift+U"
         }
      },
      "search-tabs-bookmarks": {
         "description": "Search open tabs and bookmarks",
         "suggested_key": {
            "default": "Alt+K",
            "mac": "Command+K"
         }
      }
   },
   "description": "Press ⌘K to instantly search tabs, bookmarks, history & top sites — without leaving your keyboard.",
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "QuickFind - Tab & Bookmark Search",
   "options_page": "options.html",
   "permissions": [ "storage", "tabs", "notifications", "bookmarks", "history", "topSites", "scripting", "activeTab" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.3.0"
}
